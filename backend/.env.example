# Server Configuration
PORT=5010
NODE_ENV=development

# PostgreSQL Database (Get free DB from https://neon.tech)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# JWT Authentication
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=7d

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:3000

# Email (Gmail SMTP)
# For Gmail: Enable 2-Step Verification, then generate App Password at:
# https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here
EMAIL_FROM="Student Companion <your_email@gmail.com>"

# Cloudinary (Optional - for file uploads)
# Sign up at https://cloudinary.com (free tier)
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
